APP_NAME=OpenBioSignal
APP_ENV=development
DATABASE_URL=sqlite:///./openbiosignal.db

# Current local default provider
LLM_PROVIDER=zai

# OpenAI-compatible placeholders for future provider switching
OPENAI_API_KEY=
OPENAI_MODEL=

# Z.AI configuration used by the current app
ZAI_API_KEY=
ZAI_MODEL=glm-5
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
